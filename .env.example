# Agente Solar Inteligente - Variables de entorno

# Base de Datos MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=solar_user
MYSQL_PASSWORD=solar_pass_2026
MYSQL_DATABASE=agente_solar_db

# JWT Auth
SECRET_KEY=tu-clave-secreta-super-segura-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# APIs Externas
# --- NÚCLEO: Open-Meteo (no requiere API key) ---
OPENMETEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPENMETEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
OPENMETEO_AIR_QUALITY_URL=https://air-quality-api.open-meteo.com/v1/air-quality

# --- COMPLEMENTO: OpenWeather (requiere API key gratuita) ---
OPENWEATHER_API_KEY=tu_api_key_openweather
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# --- OPCIONAL: PVGIS (baseline TMY) ---
PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_3
PVGIS_ENABLED=true

# --- LEGACY: NASA POWER (respaldo histórico) ---
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# Coordenadas Riohacha, La Guajira
RIOHACHA_LAT=11.5444
RIOHACHA_LON=-72.9072

# Ollama (LLM Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Streamlit
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000

# Configuración general
ENVIRONMENT=development
LOG_LEVEL=INFO
